#!/bin/bash
# nomad-init.sh script template — this is the core logic:
# - Loop/poll the Nomad health endpoint until it responds (Nomad takes a few seconds to start)
# - If health returns 200 → already initialised, create a marker file and exit cleanly
# - If health returns 501 → run nomad operator init -recovery-shares=3 -recovery-threshold=2 -format=json
# - Save the full JSON output (contains root_token + recovery_keys_b64) to a file like /root/nomad-init.json with chmod 600 so only root can read it
# - Write a marker file (e.g. /etc/nomad.d/.nomad-initialized) so the service never runs again on subsequent reboots


for i in {1..30}; do
  if [ -f {{ NOMAD_INIT_DIR }}/nomad-init.json ]; then
          exit 0
  fi
  curl -s -o /dev/null -w "%{http_code}" {{ NOMAD_ADDR }}/v1/status/leader | grep -q "200"
  if [ $? -eq 0 ]; then
    echo "Initializing Nomad..."
    touch {{ NOMAD_INIT_DIR }}/nomad-init.json
    chmod 600 {{ NOMAD_INIT_DIR }}/nomad-init.json
    nomad acl bootstrap -json -address={{ NOMAD_ADDR }} > {{ NOMAD_INIT_DIR }}/nomad-init.json
    NOMAD_INIT_JSON=$(cat {{ NOMAD_INIT_DIR }}/nomad-init.json)
    NOMAD_SECRET_ID=$(echo $NOMAD_INIT_JSON | jq -r '.SecretID')
    export VAULT_ADDR={{ vault_address }}
    vault login -method=gcp -path=core/gcp role=nomad_server > /dev/null
    vault kv put core/nomad/bootstrap secret_id=$NOMAD_SECRET_ID

    touch {{ NOMAD_INIT_DIR }}/.nomad-initialized
    exit 0
  else
    echo "Waiting for Nomad to be ready... (attempt $i/30)"
    sleep $((5*i))
  fi